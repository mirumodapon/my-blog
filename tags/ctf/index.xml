&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&amp;lt;script&amp;gt;var &lt;span class="nv">wechallinfo&lt;/span> &lt;span class="o">=&lt;/span> &lt;span class="o">{&lt;/span> &lt;span class="s2">&amp;#34;level&amp;#34;&lt;/span>: &lt;span class="s2">&amp;#34;natas5&amp;#34;&lt;/span>, &lt;span class="s2">&amp;#34;pass&amp;#34;&lt;/span>: &lt;span class="s2">&amp;#34;********************************&amp;#34;&lt;/span> &lt;span class="o">}&lt;/span>&lt;span class="p">;&lt;/span>&amp;lt;/script&amp;gt;&amp;lt;/head&amp;gt;
